# KAIROS Health — Environment Variables
#
# Variables marked [REQUIRED] will cause the app to crash in production
# if they are empty or missing.  All other variables are optional and
# fall back to sensible defaults.
#
# See src/lib/config/env.ts for the full validation logic.

# ─── Clerk Authentication [REQUIRED in production] ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/1

# ─── Database (PostgreSQL / Neon) [REQUIRED in production] ───
DATABASE_URL=postgresql://kairos:password@localhost:5432/kairos_dev

# ─── Redis (optional, for caching) ───
REDIS_URL=redis://localhost:6379

# ─── Stripe [REQUIRED in production] ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email (Resend) ───
RESEND_API_KEY=re_...
EMAIL_FROM=KAIROS Health <noreply@kairos.health>

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Cron Jobs [REQUIRED in production] ───
CRON_SECRET=your-cron-secret-here

# ─── Device Integrations (OAuth) ───
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_WEBHOOK_SECRET=

DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_WEBHOOK_SECRET=

GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
GARMIN_WEBHOOK_SECRET=

FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_WEBHOOK_SECRET=

# ─── Feature Flags (defaults shown, override as needed) ───
# ENABLE_DEMO_MODE=false
# ENABLE_REALTIME=true
# ENABLE_DEVICE_SYNC=false
# ENABLE_LAB_ORDERING=false
# ENABLE_COACH_MESSAGING=false

# ─── Performance (optional) ───
# CACHE_MAX_SIZE=5000
# RATE_LIMIT_ENABLED=true
