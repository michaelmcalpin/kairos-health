{
  "expo": {
    "name": "Everist.ai",
    "slug": "everist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "everist",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.everist.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Everist.ai uses the camera to scan health documents and capture progress photos.",
        "NSPhotoLibraryUsageDescription": "Everist.ai accesses your photo library to upload health documents and progress photos.",
        "NSFaceIDUsageDescription": "Everist.ai uses Face ID for secure authentication.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "ai.everist.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/fix-fmt-consteval",
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Everist.ai to access your camera for scanning health documents."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A90D9"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Everist.ai to use Face ID for secure authentication."
        }
      ],
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "de1593e7-ee5f-4793-bc1d-0f789cd3696d"
      }
    },
    "owner": "michael-everist"
  }
}
